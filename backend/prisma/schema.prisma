// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  fullName          String?   @map("full_name")
  phone             String?
  avatarUrl         String?   @map("avatar_url")
  timezone          String    @default("UTC")
  isEmailVerified   Boolean   @default(false) @map("is_email_verified")
  status            String    @default("active") // active, suspended, deleted
  lastLoginAt       DateTime? @map("last_login_at")
  loginCount        Int       @default(0) @map("login_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  ownedTenants       Tenant[]              @relation("TenantOwner")
  tenantMemberships  TenantMember[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  sessions           Session[]
  auditLogs          AuditLog[]
  notifications      Notification[]

  @@map("users")
}

// ============================================
// TENANT (ORGANIZATION) MANAGEMENT
// ============================================

model Tenant {
  id                  String    @id @default(uuid())
  name                String
  domain              String?   @unique
  billingEmail        String?   @map("billing_email")
  billingName         String?   @map("billing_name")
  logoUrl             String?   @map("logo_url")
  timezone            String    @default("UTC")
  ownerUserId         String    @map("owner_user_id")
  status              String    @default("active") // active, suspended, deleted
  isPersonal          Boolean   @default(false) @map("is_personal")
  maxMembers          Int?      @map("max_members")
  razorpayCustomerId  String?   @map("razorpay_customer_id")
  settings            Json?     // Flexible JSONB for tenant settings
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Relations
  owner          User             @relation("TenantOwner", fields: [ownerUserId], references: [id])
  members        TenantMember[]
  subscriptions  Subscription[]
  payments       Payment[]
  invoices       Invoice[]
  auditLogs      AuditLog[]
  notifications  Notification[]

  @@index([domain])
  @@map("tenants")
}

model TenantMember {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      String   // admin, member, viewer
  status    String   @default("active") // active, inactive
  joinedAt  DateTime @default(now()) @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_members")
}

// ============================================
// SUBSCRIPTION & BILLING
// ============================================

model Plan {
  id            String   @id @default(uuid())
  name          String
  price         Decimal  @db.Decimal(10, 2)
  billingCycle  String   @map("billing_cycle") // monthly, yearly
  trialDays     Int      @default(0) @map("trial_days")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  planId       String @map("plan_id")
  featureName  String @map("feature_name")
  featureValue String @map("feature_value")

  // Relations
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([planId, featureName])
  @@map("plan_features")
}

model Subscription {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  planId               String    @map("plan_id")
  status               String    // trialing, active, past_due, canceled, unpaid
  billingCycle         String    @map("billing_cycle") // monthly, yearly
  startDate            DateTime  @map("start_date")
  endDate              DateTime? @map("end_date")
  nextBillingDate      DateTime? @map("next_billing_date")
  trialStart           DateTime? @map("trial_start")
  trialEnd             DateTime? @map("trial_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime? @map("canceled_at")
  cancellationReason   String?   @map("cancellation_reason")
  razorpaySubscriptionId String? @unique @map("razorpay_subscription_id")
  razorpayPlanId       String?   @map("razorpay_plan_id")
  metadata             Json?     // Store additional Razorpay data
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]
  invoices Invoice[]

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  subscriptionId     String?   @map("subscription_id")
  amount             Decimal   @db.Decimal(10, 2)
  currency           String    @default("INR")
  provider           String    // razorpay, stripe
  providerPaymentId  String?   @unique @map("provider_payment_id")
  razorpayOrderId    String?   @map("razorpay_order_id")
  razorpaySignature  String?   @map("razorpay_signature")
  paymentMethod      String?   @map("payment_method") // card, upi, netbanking
  status             String    // success, failed, pending
  invoiceUrl         String?   @map("invoice_url")
  receiptNumber      String?   @map("receipt_number")
  failureReason      String?   @map("failure_reason")
  metadata           Json?     // Additional payment data
  createdAt          DateTime  @default(now()) @map("created_at")

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  invoices     Invoice[]

  @@index([tenantId])
  @@index([status])
  @@map("payments")
}

model Invoice {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  subscriptionId String?   @map("subscription_id")
  paymentId      String?   @map("payment_id")
  invoiceNumber  String    @unique @map("invoice_number")
  amount         Decimal   @db.Decimal(10, 2)
  taxAmount      Decimal   @default(0) @db.Decimal(10, 2) @map("tax_amount")
  totalAmount    Decimal   @db.Decimal(10, 2) @map("total_amount")
  currency       String    @default("INR")
  status         String    // draft, sent, paid, overdue
  issuedAt       DateTime? @map("issued_at")
  dueAt          DateTime? @map("due_at")
  paidAt         DateTime? @map("paid_at")
  pdfUrl         String?   @map("pdf_url")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  payment      Payment?      @relation(fields: [paymentId], references: [id])

  @@map("invoices")
}

// ============================================
// AUTHENTICATION & SECURITY
// ============================================

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model Session {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @map("refresh_token_hash")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ============================================
// AUDIT & NOTIFICATIONS
// ============================================

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String?  @map("tenant_id")
  userId       String?  @map("user_id")
  action       String   // login, logout, payment, subscription_change
  resourceType String?  @map("resource_type") // user, tenant, subscription, payment
  resourceId   String?  @map("resource_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  metadata     Json?    // Additional context
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tenantId  String?   @map("tenant_id")
  type      String    // payment_success, trial_ending, subscription_expired
  title     String
  message   String?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model WebhookLog {
  id          String    @id @default(uuid())
  provider    String    // razorpay
  eventType   String    @map("event_type") // payment.success, subscription.cancelled
  payload     Json      // Full webhook payload
  status      String    // received, processed, failed
  processedAt DateTime? @map("processed_at")
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([provider])
  @@index([eventType])
  @@index([createdAt])
  @@map("webhooks_log")
}
